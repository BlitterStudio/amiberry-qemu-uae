From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Dimitris Panokostas <midwan@gmail.com>
Date: Wed, 24 Jun 2026 13:55:00 +0200
Subject: [PATCH] DEBUG: instrument PPC stall (IO traffic + polled-EA + EXT IRQ)

Diagnostic only (issue #2114): OS3/WarpUP PPC spins polling a shared-RAM byte
(0x..ab5f) for value 2 that never arrives; m68k handshake stalls. Log every PPC
indirect IO read/write (IOR/IOW -- shows PPC->m68k INTREQ signalling), every
m68k->PPC external interrupt (EXT IRQ), and on pause dump CPU state + code at
NIP + the decoded polled effective address/value/phys-mapping. Revert before
release.
---
--- a/uae/qemu-uae-cpu.c
+++ b/uae/qemu-uae-cpu.c
@@ -54,22 +54,26 @@
 
 static uint64_t indirect_read(void *opaque, hwaddr addr, unsigned size)
 {
+    uint64_t retval = 0;
     addr += (uintptr_t) opaque;
     if (size == 8) {
-        uint64_t retval = 0;
         uae_ppc_io_mem_read64(addr, &retval);
-        return retval;
     } else {
-        uint32_t retval = 0;
-        uae_ppc_io_mem_read(addr, &retval, size);
-        return retval;
-    }
+        uint32_t r32 = 0;
+        uae_ppc_io_mem_read(addr, &r32, size);
+        retval = r32;
+    }
+    uae_log("QEMU: IOR %08x = %08x sz%u\n", (uint32_t)addr,
+            (uint32_t)retval, size);
+    return retval;
 }
 
 static void indirect_write(void *opaque, hwaddr addr, uint64_t data,
                            unsigned size)
 {
     addr += (uintptr_t) opaque;
+    uae_log("QEMU: IOW %08x = %08x sz%u\n", (uint32_t)addr,
+            (uint32_t)data, size);
     if (size == 8) {
         uae_ppc_io_mem_write64(addr, data);
     } else {
@@ -325,6 +329,8 @@
 
 void PPCAPI qemu_uae_ppc_external_interrupt(bool enable)
 {
+    uae_log("QEMU: EXT IRQ %d nip=%08x\n", enable ? 1 : 0,
+            (uint32_t)(state.env ? state.env->nip : 0));
     ppc_set_irq(state.cpu, PPC_INTERRUPT_EXT, enable ? 1 : 0);
 }
 
@@ -391,8 +397,67 @@
 static void qemu_uae_log_cpu_state(void)
 {
     int flags = 0;
+    CPUPPCState *env = state.env;
+    uint8_t code[64];
+    uint8_t ib[4];
+    uint32_t base = ((uint32_t)env->nip & ~(uint32_t)0xf) - 16u;
     uae_log("QEMU: PPC CPU dump:\n");
     cpu_dump_state(CPU(state.cpu), stderr, flags);
+    uae_log("QEMU: DUMP nip=%08x lr=%08x ctr=%08x msr=%08x srr0=%08x srr1=%08x res=%08x\n",
+            (uint32_t)env->nip, (uint32_t)env->lr, (uint32_t)env->ctr,
+            (uint32_t)env->msr, (uint32_t)env->spr[SPR_SRR0],
+            (uint32_t)env->spr[SPR_SRR1], (uint32_t)env->reserve_addr);
+    if (cpu_memory_rw_debug(CPU(state.cpu), base, code, sizeof(code), false) == 0) {
+        for (int i = 0; i < (int)sizeof(code); i += 16) {
+            uae_log("QEMU: INSN %08x: %02x%02x%02x%02x %02x%02x%02x%02x "
+                    "%02x%02x%02x%02x %02x%02x%02x%02x\n",
+                    base + (uint32_t)i,
+                    code[i + 0], code[i + 1], code[i + 2], code[i + 3],
+                    code[i + 4], code[i + 5], code[i + 6], code[i + 7],
+                    code[i + 8], code[i + 9], code[i + 10], code[i + 11],
+                    code[i + 12], code[i + 13], code[i + 14], code[i + 15]);
+        }
+    } else {
+        uae_log("QEMU: INSN read failed at %08x\n", base);
+    }
+    /* If the stuck instruction is a D-form load, decode its effective
+     * address and dump the polled memory (the m68k's view of that RAM,
+     * since cpu_memory_rw_debug reads current host RAM via a fresh page
+     * walk). POLLMEM==expected-but-still-looping => PPC's cached TLB is
+     * stale (coherency); POLLMEM!=expected => m68k never wrote it
+     * (sequencing). pa shows the VA->PA mapping for the polled address. */
+    if (cpu_memory_rw_debug(CPU(state.cpu), (uint32_t)env->nip, ib, 4, false) == 0) {
+        uint32_t in = ((uint32_t)ib[0] << 24) | ((uint32_t)ib[1] << 16) |
+                      ((uint32_t)ib[2] << 8) | (uint32_t)ib[3];
+        uint32_t op = in >> 26;
+        /* lwz/lbz/lhz/lha and their update forms */
+        if (op == 32 || op == 33 || op == 34 || op == 35 ||
+            op == 40 || op == 41 || op == 42 || op == 43) {
+            int ra = (int)((in >> 16) & 0x1f);
+            int32_t d = (int32_t)(int16_t)(in & 0xffff);
+            uint32_t ea = (uint32_t)env->gpr[ra] + (uint32_t)d;
+            uint8_t poll[32];
+            uint32_t pbase = ea & ~(uint32_t)0xf;
+            hwaddr pa = cpu_get_phys_page_debug(CPU(state.cpu),
+                                                ea & ~(target_ulong)0xfff);
+            uae_log("QEMU: POLL insn=%08x op=%u ra=r%d d=%d ea=%08x pa=%08x\n",
+                    in, op, ra, d, ea, (uint32_t)pa);
+            if (cpu_memory_rw_debug(CPU(state.cpu), pbase, poll, sizeof(poll),
+                                    false) == 0) {
+                for (int i = 0; i < (int)sizeof(poll); i += 16) {
+                    uae_log("QEMU: POLLMEM %08x: %02x%02x%02x%02x %02x%02x%02x%02x "
+                            "%02x%02x%02x%02x %02x%02x%02x%02x\n",
+                            pbase + (uint32_t)i,
+                            poll[i + 0], poll[i + 1], poll[i + 2], poll[i + 3],
+                            poll[i + 4], poll[i + 5], poll[i + 6], poll[i + 7],
+                            poll[i + 8], poll[i + 9], poll[i + 10], poll[i + 11],
+                            poll[i + 12], poll[i + 13], poll[i + 14], poll[i + 15]);
+                }
+            } else {
+                uae_log("QEMU: POLLMEM read failed at %08x\n", pbase);
+            }
+        }
+    }
 }
 
 void PPCAPI ppc_cpu_set_state(int set_state)
