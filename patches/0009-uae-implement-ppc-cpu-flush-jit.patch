From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Dimitris Panokostas <midwan@gmail.com>
Date: Wed, 24 Jun 2026 18:45:00 +0200
Subject: [PATCH] uae: implement and export ppc_cpu_flush_jit (timer-driven)

AmigaOS 3.x / WarpOS drives the PPC as a coprocessor: the m68k patches PPC
code/data directly in shared RAM, bypassing QEMU's PPC softmmu, so the PPC runs
stale translation blocks and the handshake deadlocks (BlitterStudio/amiberry
#2114). The old qemu-uae plugin exported ppc_cpu_flush_jit; the QEMU 11 port
dropped it. Reinstate + export it. In QEMU 11 the flush must run on a QEMU
thread (a synchronous flush asserts, and queue_tb_flush from the m68k thread
hard-locks), so ppc_cpu_flush_jit() (called by UAE from the m68k thread) only
sets an atomic flag; a 1ms main-loop-thread timer does the actual coalescing
queue_tb_flush. UAE only requests a flush at an m68k->PPC handoff and never
while the m68k is halted, so OS4 PPC-only execution is unaffected.
---
 uae/qemu-uae-cpu.c        | 35 +++++++++++++++++++++++++++++++++++
 uae/qemu-uae-ld64.symbols |  1 +
 uae/qemu-uae.symbols      |  1 +
 3 files changed, 37 insertions(+)

--- a/uae/qemu-uae-cpu.c
+++ b/uae/qemu-uae-cpu.c
@@ -32,6 +32,7 @@
 #include "system/address-spaces.h"
 #include "system/reset.h"
 #include "exec/tb-flush.h"
+#include "qemu/timer.h"
 #include "cpu.h"
 #include "helper_regs.h"
 #include "qemu-uae.h"
@@ -343,6 +344,28 @@
     return result;
 }
 
+/*
+ * UAE requests a PPC TB flush (the m68k patched PPC code in shared RAM, #2114)
+ * from the m68k thread. In QEMU 11 the flush must run on a QEMU thread: a
+ * synchronous flush asserts (we are not a vcpu in serial context) and
+ * queue_tb_flush()/async_safe_run_on_cpu() called from a non-vcpu host thread
+ * hard-locks the emulator. So ppc_cpu_flush_jit() only sets an atomic request
+ * flag, and this timer -- armed on the QEMU main-loop thread, where
+ * queue_tb_flush is safe -- performs the actual coalescing flush. The 1ms period
+ * also rate-limits it so it cannot drown the PPC in retranslation (OS4 stays
+ * fast because UAE never requests a flush while the m68k is halted).
+ */
+static int uae_flush_requested;
+static QEMUTimer *uae_flush_timer;
+
+static void uae_flush_timer_cb(void *opaque)
+{
+    if (qatomic_xchg(&uae_flush_requested, 0) && state.cpu) {
+        queue_tb_flush(CPU(state.cpu));
+    }
+    timer_mod(uae_flush_timer, qemu_clock_get_ms(QEMU_CLOCK_REALTIME) + 1);
+}
+
 void PPCAPI ppc_cpu_run_continuous(void)
 {
     uae_log("QEMU: Running main loop\n");
@@ -355,6 +378,12 @@
 
     qemu_uae_set_started();
 
+    /* Arm the PPC JIT-flush timer on the main-loop thread (see
+     * ppc_cpu_flush_jit). */
+    uae_flush_timer = timer_new_ms(QEMU_CLOCK_REALTIME, uae_flush_timer_cb,
+                                   NULL);
+    timer_mod(uae_flush_timer, qemu_clock_get_ms(QEMU_CLOCK_REALTIME) + 1);
+
     /* The main loop iteration unlocks and relocks the iothread lock */
     main_loop();
 }
@@ -388,6 +417,11 @@
     }
 }
 
+void PPCAPI ppc_cpu_flush_jit(void)
+{
+    qatomic_set(&uae_flush_requested, 1);
+}
+
 static void qemu_uae_log_cpu_state(void)
 {
     int flags = 0;
--- a/uae/qemu-uae.symbols
+++ b/uae/qemu-uae.symbols
@@ -1,5 +1,6 @@
 {
   global:
+    ppc_cpu_flush_jit;
     ppc_cpu_init;
     ppc_cpu_map_memory;
     ppc_cpu_reset;
--- a/uae/qemu-uae-ld64.symbols
+++ b/uae/qemu-uae-ld64.symbols
@@ -1,3 +1,4 @@
+_ppc_cpu_flush_jit
 _ppc_cpu_init
 _ppc_cpu_map_memory
 _ppc_cpu_reset
